# Yerel telemetry (uvicorn quinkgl.telemetry.server:create_telemetry_app --factory --port 8765).
# Vite dev sunucusu /api ve /api/ws isteklerini buraya yönlendirir.
# QUINKGL_TELEMETRY_DEV_URL=http://127.0.0.1:8765

# İsteğe bağlı: proxy kullanmadan doğrudan telemetry kökü (tarayıcıdan cross-origin;
# sunucuda QUINKGL_TELEMETRY_CORS_ALLOW_ORIGINS=http://localhost:5173 gerekir).
# VITE_QUINKGL_DASHBOARD_API_BASE=http://127.0.0.1:8765/api
